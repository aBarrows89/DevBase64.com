# Convex deployment URL (get this from npx convex dev)
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud

# GitHub Personal Access Token (for repository sync)
GITHUB_ACCESS_TOKEN=your_github_token_here

# App URL (used for OAuth redirects)
NEXT_PUBLIC_APP_URL=https://iecentral.com

# ===========================================
# Email Client Configuration
# ===========================================

# Encryption key for storing OAuth tokens and IMAP passwords
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# REQUIRED: Must be a 64-character hex string (32 bytes)
EMAIL_ENCRYPTION_KEY=

# Google OAuth (Gmail)
# Create credentials at: https://console.developers.google.com/
# Required scopes: gmail.readonly, gmail.send, gmail.modify
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Microsoft OAuth (Outlook)
# Create credentials at: https://portal.azure.com/
# Required scopes: Mail.ReadWrite, Mail.Send, offline_access
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# Yahoo OAuth
# Create credentials at: https://developer.yahoo.com/apps/
# Required scopes: mail-r, mail-w
YAHOO_CLIENT_ID=
YAHOO_CLIENT_SECRET=
